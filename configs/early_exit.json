{
  "seed": 42,
  "device": "auto",
  "num_workers": 2,
  "data": {
    "root": "data",
    "batch_size": 128,
    "val_split": 0.1
  },
  "training": {
    "epochs": 25,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "loss_weights": [0.3, 0.5, 0.7, 1.0]
  },
  "outputs": {
    "checkpoint_dir": "checkpoints",
    "metrics_dir": "outputs/metrics",
    "plots_dir": "outputs/plots"
  }
}
